# Environment Configuration
# Copy this file to .env and update values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=hr_analytics
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@localhost:5432/hr_analytics

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-must-be-32-chars

# API
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
WORKERS=4

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Models (Local paths)
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5
LLM_MODEL_PATH=./models/qwen2-72b-instruct.Q4_K_M.gguf

# GPU Settings
USE_GPU=true
GPU_LAYERS=-1

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
